NODE_ENV=development
PORT=4000

# JWT / Zero Trust
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=8h
REFRESH_TOKEN_SECRET=your-refresh-token-secret

# PGP Encryption
PGP_PASSPHRASE=your-pgp-passphrase

# SAP BTP / CPI
SAP_BTP_HOST=https://your-tenant.hana.ondemand.com
SAP_CPI_HOST=https://your-cpi-tenant.hana.ondemand.com
SAP_CLIENT_ID=your-sap-client-id
SAP_CLIENT_SECRET=your-sap-client-secret
SAP_TOKEN_URL=https://your-tenant.authentication.hana.ondemand.com/oauth/token

# Azure Arc
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id
AZURE_RESOURCE_GROUP=cloudbridge-rg

# IoT / InfluxDB
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=cloudbridge
INFLUXDB_BUCKET=carbon_metrics

# Redis Cache
REDIS_URL=redis://localhost:6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://cloudbridge.yourorg.com
